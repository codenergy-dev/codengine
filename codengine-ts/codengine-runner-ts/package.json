{
  "name": "codengine-runner-ts",
  "version": "0.1.0",
  "description": "Execute the codengine IR (Intermediate Representation) in TypeScript/Node.",
  "license": "MIT",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "codengine-run-ts": "dist/src/cli.js"
  },
  "files": [
    "dist/src"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsc && node --test \"dist/test/**/*.test.js\""
  },
  "dependencies": {
    "codengine-loader-ts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "typescript": "5.9.2"
  }
}
