{
  "name": "codengine-worker-ts",
  "version": "0.1.0",
  "description": "A persistent TS/JS worker: execute a module's task functions on request (the executor for cross-language runs).",
  "license": "MIT",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "codengine-worker-ts": "dist/src/cli.js"
  },
  "files": [
    "dist/src"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test \"dist/test/**/*.test.js\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "codengine-core-ts": "workspace:*",
    "codengine-loader-ts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "typescript": "5.9.2"
  }
}
