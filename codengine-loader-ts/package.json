{
  "name": "codengine-loader-ts",
  "version": "0.1.0",
  "description": "Load TS/JS task functions (a module's files) into a function map.",
  "license": "MIT",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
